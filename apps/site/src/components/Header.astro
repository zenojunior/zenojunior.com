---
import { Github, Linkedin } from 'lucide-astro'
import { FEATURES } from '../consts'

const pathname = Astro.url.pathname

const links = [
  { href: '/', label: 'Home' },
  ...(FEATURES.notes ? [{ href: '/notes', label: 'Notes' }] : []),
  { href: '/projects', label: 'Projects' },
  { href: '/resume', label: 'Resume' },
]

function isActive(href: string) {
  return href === '/' ? pathname === '/' : pathname.startsWith(href)
}
---

<header class="fixed top-4 left-1/2 -translate-x-1/2 z-50">
  <nav class="pill-nav relative flex items-center gap-0.5 rounded-full border border-border bg-bg-secondary/70 backdrop-blur-md p-1.5 shadow-lg shadow-black/20">
    <!-- Sliding highlight (positioned via JS) -->
    <span class="nav-highlight pointer-events-none absolute left-0 top-0 rounded-full bg-bg-card opacity-0 transition-all duration-300 ease-out"></span>

    {links.map(link => (
      <a
        href={link.href}
        class="nav-item relative z-10 px-3.5 py-1.5 rounded-full text-sm text-text-secondary hover:text-text transition-colors"
        aria-current={isActive(link.href) ? 'page' : undefined}
      >
        {link.label}
      </a>
    ))}

    <span class="mx-1 h-5 w-px bg-border"></span>

    <a href="https://github.com/zenojunior" target="_blank" rel="noopener" aria-label="GitHub" class="nav-item relative z-10 p-2 rounded-full text-text-secondary hover:text-text transition-colors">
      <Github size={17} />
    </a>
    <a href="https://www.linkedin.com/in/zenojunior" target="_blank" rel="noopener" aria-label="LinkedIn" class="nav-item relative z-10 p-2 rounded-full text-text-secondary hover:text-text transition-colors">
      <Linkedin size={17} />
    </a>
  </nav>
</header>

<script>
  const nav = document.querySelector<HTMLElement>('.pill-nav')
  if (nav) {
    const highlight = nav.querySelector<HTMLElement>('.nav-highlight')!
    const items = [...nav.querySelectorAll<HTMLElement>('.nav-item')]
    const active = items.find(el => el.getAttribute('aria-current') === 'page') ?? null

    function moveTo(el: HTMLElement | null) {
      if (!el) {
        highlight.style.opacity = '0'
        return
      }
      highlight.style.opacity = '1'
      highlight.style.width = `${el.offsetWidth}px`
      highlight.style.height = `${el.offsetHeight}px`
      highlight.style.transform = `translate(${el.offsetLeft}px, ${el.offsetTop}px)`
    }

    moveTo(active)
    items.forEach(item => item.addEventListener('mouseenter', () => moveTo(item)))
    nav.addEventListener('mouseleave', () => moveTo(active))
    window.addEventListener('resize', () => moveTo(active))
    document.fonts?.ready.then(() => moveTo(active))
  }
</script>
