---
import type { ImageMetadata } from 'astro'
import { config } from '../config'

// Avatar variants from src/avatars (1.webp, 2.webp, …). Click the avatar to
// advance to the next one with a crossfade. Add or remove files there — they're
// auto-detected and sorted numerically. Falls back to /avatar.jpg when empty.
interface Props {
  class?: string
}

const { class: className = '' } = Astro.props

const modules = import.meta.glob<{ default: ImageMetadata }>('../avatars/*.{webp,png,jpg,jpeg}', { eager: true })
const images = Object.entries(modules)
  .sort(([a], [b]) => a.localeCompare(b, undefined, { numeric: true }))
  .map(([, m]) => m.default.src)
const frames = images.length ? images : ['/avatar.jpg']
const interactive = frames.length > 1
---

<div
  class:list={['avatar-carousel relative overflow-hidden rounded-full shadow-[0_8px_40px_-8px] shadow-accent/30 transition-all duration-500', interactive && 'cursor-pointer', className]}
  data-avatar-carousel
  role={interactive ? 'button' : undefined}
  tabindex={interactive ? 0 : undefined}
  aria-label={interactive ? 'Change avatar' : undefined}
>
  {frames.map((src, i) => (
    <img
      src={src}
      alt={config.name}
      data-active={i === 0 ? 'true' : 'false'}
      class="avatar-frame absolute inset-0 h-full w-full object-cover"
    />
  ))}
</div>

<style>
	.avatar-frame {
		opacity: 0;
		transform: scale(1.06);
		transition: opacity 0.5s ease, transform 0.5s ease;
	}
	.avatar-frame[data-active='true'] {
		opacity: 1;
		transform: scale(1);
	}
</style>

<script>
const root = document.querySelector<HTMLElement>('[data-avatar-carousel]')
const frames = root ? [...root.querySelectorAll<HTMLImageElement>('.avatar-frame')] : []

if (root && frames.length > 1) {
  let i = 0
  const next = () => {
    frames[i].dataset.active = 'false'
    i = (i + 1) % frames.length
    frames[i].dataset.active = 'true'
  }
  root.addEventListener('click', next)
  root.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault()
      next()
    }
  })
}
</script>
