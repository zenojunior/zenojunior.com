---
// Giscus comments (GitHub Discussions backend). Renders only when configured in
// config.yaml; fill the IDs from https://giscus.app after enabling Discussions
// and installing the giscus GitHub App on the repo.
import { config } from '../config'

const c = config.comments
const enabled = Boolean(c?.repo && c?.repoId && c?.categoryId)
---

{enabled && (
  <section class="mt-16 pt-8 border-t border-border giscus-wrap" aria-label="Comments">
    <h2 class="font-mono text-xs uppercase tracking-wider text-accent mb-6">Comments</h2>
    <script
      is:inline
      src="https://giscus.app/client.js"
      data-repo={c!.repo}
      data-repo-id={c!.repoId}
      data-category={c!.category}
      data-category-id={c!.categoryId}
      data-mapping="pathname"
      data-strict="1"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="top"
      data-theme="transparent_dark"
      data-lang="en"
      data-loading="lazy"
      crossorigin="anonymous"
      async
    ></script>
  </section>
)}
