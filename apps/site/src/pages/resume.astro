---
import { resumeData } from '@zenojunior/cv'
import CVPage from '@zenojunior/cv/CVPage.astro'
import { ArrowLeft, Download } from 'lucide-astro'
import BaseHead from '../components/BaseHead.astro'
import { SITE_TITLE } from '../consts'
import '@zenojunior/cv/styles'
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Resume - ${SITE_TITLE}`} description="Download my resume." />
  </head>
  <body class="resume-viewer">
    <!-- Viewer toolbar -->
    <div class="toolbar fixed top-0 inset-x-0 z-50 flex items-center justify-between gap-4 px-4 h-14 border-b border-border bg-bg-secondary/80 backdrop-blur-md print:hidden">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-sm px-3 py-1.5 rounded-md text-text-secondary hover:text-text hover:bg-bg-card/60 transition-colors"
      >
        <ArrowLeft size={16} />
        <span>Back</span>
      </a>

      <span class="font-mono text-xs uppercase tracking-wider text-text-muted">Resume Viewer</span>

      <button
        onclick="window.print()"
        class="inline-flex items-center gap-2 text-sm px-4 py-1.5 bg-accent text-bg font-medium rounded-md hover:bg-accent-hover transition-colors cursor-pointer"
      >
        <Download size={16} />
        <span>Download</span>
      </button>
    </div>

    <main class="pt-14 min-h-screen flex justify-center">
      <div class="cv-wrapper w-full flex justify-center px-4 py-8 max-md:px-2 max-md:py-4">
        <CVPage data={resumeData} />
      </div>
    </main>
  </body>
</html>

<style>
	.cv-wrapper {
		overflow-x: auto;
	}
</style>

<style is:global>
	@media print {
		.toolbar {
			display: none !important;
		}
		body,
		main {
			margin: 0 !important;
			padding: 0 !important;
			background: #fff !important;
		}
		main {
			min-height: 0 !important;
			padding-top: 0 !important;
		}
		.cv-wrapper {
			display: block !important;
			overflow: visible !important;
			padding: 0 !important;
		}
		.cv-page {
			width: 210mm !important;
			min-height: 0 !important;
			height: auto !important;
			margin: 0 !important;
			padding: 8mm 12mm !important;
			box-shadow: none !important;
			transform: none !important;
			page-break-after: avoid;
			page-break-inside: avoid;
		}
		@page {
			size: A4;
			margin: 0;
		}
	}
</style>
